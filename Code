with torch.no_grad():
    x_test = torch.linspace(0, 1, 100).unsqueeze(1).to(device)
    t_test = torch.full((100, 1), 0.5).to(device)   # t = 0.5
    u_pred = model(x_test, t_test).cpu().numpy()

